# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# App data (mount via Docker volumes on NAS)
/data/games.json
/data/game_db.json
/data/ai-cache.json
/data/last-sync.json
/data/settings.json
/data/library-images/
/data/cartridges/
/public/cartridges/
/pocket-data/
/analogue-pocket-library/

# Demo-Daten Inhalte (Ordner selbst per .gitkeep tracken)
/data/analogue-pocket-playedgames/
/data/screenshots/*.png
/data/screenshots/*.jpg
/data/screenshots/*.jpeg
/data/screenshots/*.bmp
/data/screenshots/*.gif
/data/screenshot-meta.json
/analogue-pocket-screenshots/
